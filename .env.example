# Copy to .env and fill in. The leaf node reads SYNC_HUB_* via nats-server's
# environment-variable expansion; the daemon reads the rest via tooling/config.js.

# --- Central hub (used by nats/hub.conf and nats/leaf.conf) ---
SYNC_HUB_HOST=hub.internal.example.com
SYNC_HUB_PASSWORD=change-me

# --- Sync daemon (tooling/sync-daemon.js) ---
# Point at the LOCAL leaf node, not the hub.
NATS_URL=nats://127.0.0.1:4222

# Unique identity for this agent/machine (defaults to hostname).
AGENT_ID=alice-laptop

# JetStream stream + subject namespace (must match across the team).
SYNC_STREAM=TEAM_SYNC
SYNC_SUBJECT_PREFIX=team.sync.events

# How the daemon refreshes the local Graphify AST map after a peer edit.
# `graphify update .` re-extracts code into graphify-out/graph.json (no LLM call).
GRAPHIFY_CMD=graphify update .
